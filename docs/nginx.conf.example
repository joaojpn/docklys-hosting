# Frontend
server {
    listen 80;
    server_name docklys.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name docklys.io;

    ssl_certificate /etc/letsencrypt/live/docklys.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/docklys.io/privkey.pem;

    root /opt/docklys/apps/web/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;
    }
}

# API
server {
    listen 80;
    server_name api.docklys.io;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name api.docklys.io;

    ssl_certificate /etc/letsencrypt/live/api.docklys.io/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/api.docklys.io/privkey.pem;

    location / {
        proxy_pass http://localhost:3333;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_cache_bypass $http_upgrade;

        # SSE support
        proxy_buffering off;
        proxy_read_timeout 24h;
    }
}
